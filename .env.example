ENVIRONMENT=development

# Gumnut API Configuration
GUMNUT_API_BASE_URL=http://localhost:8000

# Redis Configuration
# Uses db 1 for isolation from the Gumnut API (db 0)
REDIS_URL=redis://localhost:6379/1

# OAuth Mobile Redirect URI Configuration
# Custom URL scheme for mobile app deep linking during OAuth flow
# Default is for official Immich mobile app
OAUTH_MOBILE_REDIRECT_URI=app.immich:///oauth-callback

# Trash retention before scheduled purge runs on the Gumnut API side.
# Surfaced to Immich clients via /api/server/config as `trashDays`.
# Must be kept in sync with the Gumnut API's TRASH_RETENTION_DAYS at deploy time.
TRASH_RETENTION_DAYS=90

# Session Encryption Key (REQUIRED)
# Fernet key for encrypting JWTs stored in sessions
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SESSION_ENCRYPTION_KEY=
